{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },
    "detailed": {
      "format": "%(asctime)s - %(name)s - %(levelname)s - [%(filename)s:%(lineno)d] - %(funcName)s() - %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },
    "simple": {
      "format": "%(levelname)s - %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "standard",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "DEBUG",
      "formatter": "detailed",
      "filename": "docgen.log",
      "maxBytes": 10485760,
      "backupCount": 3,
      "encoding": "utf-8"
    },
    "error_file": {
      "class": "logging.FileHandler",
      "level": "ERROR",
      "formatter": "detailed",
      "filename": "docgen_errors.log",
      "encoding": "utf-8"
    }
  },
  "loggers": {
    "": {
      "level": "INFO",
      "handlers": ["console", "file"]
    },
    "utils": {
      "level": "DEBUG",
      "handlers": ["console", "file"],
      "propagate": false
    },
    "extractors": {
      "level": "DEBUG",
      "handlers": ["console", "file"],
      "propagate": false
    },
    "classifier": {
      "level": "DEBUG",
      "handlers": ["console", "file"],
      "propagate": false
    }
  },
  "root": {
    "level": "DEBUG",
    "handlers": ["console", "file", "error_file"]
  }
}
